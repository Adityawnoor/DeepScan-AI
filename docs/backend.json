
{
  "entities": {
    "ScanResult": {
      "title": "Scan Result",
      "description": "Stored results of a deepfake scan including user feedback and neural ancestry tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "mediaType": { "type": "string", "enum": ["image", "audio", "video"] },
        "aiVerdict": { "type": "boolean", "description": "True if AI thought it was a deepfake" },
        "aiConfidence": { "type": "number" },
        "explanation": { "type": "string" },
        "userFeedback": { "type": "boolean", "description": "The actual truth provided by the user" },
        "userComment": { "type": "string", "description": "Detailed text feedback from the user" },
        "isCorrect": { "type": "boolean", "description": "Whether the AI was correct" },
        "mediaUrl": { "type": "string" },
        "mediaHash": { "type": "string", "description": "SHA-256 fingerprint for blockchain notarization." },
        "blockchainTxId": { "type": "string", "description": "Mock blockchain transaction identifier." },
        "sourceOrigin": { "type": "string", "description": "The likely original source of the media (e.g., '2021 TED Talk')." },
        "originalContext": { "type": "string", "description": "Detailed notes on the identified original clip or event." },
        "neuralAncestry": {
          "type": "object",
          "properties": {
            "modelFamily": { "type": "string", "description": "e.g., Diffusion, GAN, FaceSwap, Vocoder" },
            "likelyModel": { "type": "string", "description": "e.g., Stable Diffusion XL, ElevenLabs v2" },
            "fingerprintConfidence": { "type": "number" }
          }
        },
        "behavioralBiometrics": {
          "type": "object",
          "properties": {
            "blinkConsistency": { "type": "number" },
            "headMovementFluidity": { "type": "number" },
            "speechProsody": { "type": "number" },
            "notes": { "type": "string" }
          }
        },
        "highlightedRegions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "reason": { "type": "string" }
            }
          }
        },
        "suspiciousSegments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "startTime": { "type": "number" },
              "endTime": { "type": "number" },
              "isSynthetic": { "type": "boolean" },
              "description": { "type": "string" }
            }
          }
        }
      },
      "required": ["timestamp", "mediaType", "aiVerdict"]
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "Immutable record of media authenticity on the Neural Ledger.",
      "type": "object",
      "properties": {
        "hash": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["authentic", "synthetic", "unverified"] },
        "notarizedBy": { "type": "string" },
        "forensicCaseId": { "type": "string" }
      },
      "required": ["hash", "timestamp", "status"]
    },
    "DatasetFile": {
      "title": "Dataset File",
      "description": "Information about uploaded training datasets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "size": { "type": "number" },
        "fileType": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "processed", "failed"] },
        "label": { "type": "string", "enum": ["real", "fake", "mixed", "unlabeled"] },
        "modelSignature": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["fileName", "uploadDate", "size", "label"]
    },
    "ViralAlert": {
      "title": "Viral Alert",
      "description": "Real-time monitoring record of a detected deepfake trending on social platforms.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "platform": { "type": "string", "enum": ["X", "YouTube", "Instagram", "TikTok"] },
        "contentSnippet": { "type": "string" },
        "viralVelocity": { "type": "number", "description": "Score 0-100 indicating spread speed." },
        "forensicRisk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "originalSource": { "type": "string" },
        "status": { "type": "string", "enum": ["monitoring", "verified_fake", "debunked"] }
      },
      "required": ["timestamp", "platform", "contentSnippet", "forensicRisk"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/scans/{scanId}": {
      "schema": "ScanResult",
      "description": "Collection of analyzed media and user feedback."
    },
    "/ledger/{hash}": {
      "schema": "LedgerEntry",
      "description": "The 'Blockchain' ledger mapping content hashes to authenticity proofs."
    },
    "/datasets/{datasetId}": {
      "schema": "DatasetFile",
      "description": "Metadata for uploaded training datasets."
    },
    "/alerts/{alertId}": {
      "schema": "ViralAlert",
      "description": "Trending deepfake alerts from social monitoring."
    }
  }
}
