
{
  "entities": {
    "ScanResult": {
      "title": "Scan Result",
      "description": "Stored results of a deepfake scan including user feedback and neural ancestry tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "mediaType": { "type": "string", "enum": ["image", "audio", "video"] },
        "fakeCategory": { "type": "string", "description": "The specific type of manipulation (e.g., Face Swap, Voice Clone, Style Transfer)." },
        "aiVerdict": { "type": "boolean", "description": "True if AI thought it was a deepfake" },
        "aiConfidence": { "type": "number" },
        "explanation": { "type": "string" },
        "userFeedback": { "type": "boolean", "description": "The actual truth provided by the user" },
        "userComment": { "type": "string", "description": "Detailed text feedback from the user" },
        "isCorrect": { "type": "boolean", "description": "Whether the AI was correct" },
        "mediaUrl": { "type": "string" },
        "mediaHash": { "type": "string", "description": "SHA-256 fingerprint for blockchain notarization." },
        "blockchainTxId": { "type": "string", "description": "Mock blockchain transaction identifier." },
        "sourceOrigin": { "type": "string", "description": "The likely original source of the media." },
        "originalContext": { "type": "string", "description": "Detailed notes on the identified original clip." },
        "neuralAncestry": {
          "type": "object",
          "properties": {
            "modelFamily": { "type": "string" },
            "likelyModel": { "type": "string" },
            "fingerprintConfidence": { "type": "number" }
          }
        },
        "behavioralBiometrics": {
          "type": "object",
          "properties": {
            "blinkConsistency": { "type": "number" },
            "headMovementFluidity": { "type": "number" },
            "temporalStability": { "type": "number", "description": "Score of frame-to-frame coherence (0-100)." },
            "notes": { "type": "string" }
          }
        },
        "suspiciousSegments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "startTime": { "type": "number" },
              "endTime": { "type": "number" },
              "isSynthetic": { "type": "boolean" },
              "description": { "type": "string" }
            }
          }
        }
      },
      "required": ["timestamp", "mediaType", "aiVerdict"]
    },
    "ProtectedIdentity": {
      "title": "Protected Identity",
      "description": "User's enrolled biometric fingerprint for proactive monitoring.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "enrolledAt": { "type": "string", "format": "date-time" },
        "identityName": { "type": "string" },
        "faceSignatures": { "type": "array", "items": { "type": "string" }, "description": "Neural fingerprints of the 3 enrolled photos." },
        "voiceSignature": { "type": "string", "description": "Neural fingerprint of the enrolled audio." },
        "status": { "type": "string", "enum": ["active", "alert", "archived"] }
      },
      "required": ["identityName", "faceSignatures", "voiceSignature"]
    },
    "ViralAlert": {
      "title": "Viral Alert",
      "description": "Real-time monitoring record of a detected deepfake trending on social platforms.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "platform": { "type": "string", "enum": ["X", "YouTube", "Instagram", "TikTok"] },
        "contentSnippet": { "type": "string" },
        "viralVelocity": { "type": "number" },
        "forensicRisk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "matchedIdentityId": { "type": "string", "description": "ID of a ProtectedIdentity if a breach is detected." },
        "status": { "type": "string", "enum": ["monitoring", "verified_fake", "identity_theft"] }
      },
      "required": ["timestamp", "platform", "contentSnippet", "forensicRisk"]
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "An immutable record of media authenticity notarized on the Neural Ledger.",
      "type": "object",
      "properties": {
        "hash": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["authentic", "synthetic"] },
        "txId": { "type": "string" },
        "notarizedBy": { "type": "string" },
        "forensicCaseId": { "type": "string" }
      },
      "required": ["hash", "timestamp", "status"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/scans/{scanId}": {
      "schema": "ScanResult",
      "description": "Collection of analyzed media."
    },
    "/identities/{identityId}": {
      "schema": "ProtectedIdentity",
      "description": "User's enrolled biometric profiles for monitoring."
    },
    "/alerts/{alertId}": {
      "schema": "ViralAlert",
      "description": "Trending deepfake alerts from social monitoring."
    },
    "/ledger/{hash}": {
      "schema": "LedgerEntry",
      "description": "Global immutable registry of media hashes."
    }
  }
}
