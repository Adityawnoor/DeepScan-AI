
{
  "entities": {
    "ScanResult": {
      "title": "Scan Result",
      "description": "Stored results of a deepfake scan including user feedback for accuracy tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "mediaType": { "type": "string", "enum": ["image", "audio", "video"] },
        "aiVerdict": { "type": "boolean", "description": "True if AI thought it was a deepfake" },
        "aiConfidence": { "type": "number" },
        "explanation": { "type": "string" },
        "userFeedback": { "type": "boolean", "description": "The actual truth provided by the user" },
        "userComment": { "type": "string", "description": "Detailed text feedback from the user" },
        "isCorrect": { "type": "boolean", "description": "Whether the AI was correct" },
        "mediaUrl": { "type": "string" },
        "mediaHash": { "type": "string", "description": "SHA-256 fingerprint for blockchain notarization." },
        "blockchainTxId": { "type": "string", "description": "Mock blockchain transaction identifier." },
        "behavioralBiometrics": {
          "type": "object",
          "properties": {
            "blinkConsistency": { "type": "number", "description": "Score 0-100 for natural blinking" },
            "headMovementFluidity": { "type": "number", "description": "Score 0-100 for natural movement" },
            "speechProsody": { "type": "number", "description": "Score 0-100 for natural speech rhythm" },
            "notes": { "type": "string" }
          }
        },
        "highlightedRegions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "reason": { "type": "string" }
            }
          }
        },
        "suspiciousTimestamps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "number" },
              "description": { "type": "string" }
            }
          }
        }
      },
      "required": ["timestamp", "mediaType", "aiVerdict"]
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "Immutable record of media authenticity on the Neural Ledger.",
      "type": "object",
      "properties": {
        "hash": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["authentic", "synthetic", "unverified"] },
        "notarizedBy": { "type": "string" },
        "forensicCaseId": { "type": "string" }
      },
      "required": ["hash", "timestamp", "status"]
    },
    "DatasetFile": {
      "title": "Dataset File",
      "description": "Information about uploaded training datasets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "size": { "type": "number" },
        "fileType": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "processed", "failed"] },
        "label": { "type": "string", "enum": ["real", "fake", "mixed", "unlabeled"], "description": "The primary truth label for the contents of the dataset." },
        "notes": { "type": "string", "description": "User-provided description or notes for the dataset." }
      },
      "required": ["fileName", "uploadDate", "size", "label"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/scans/{scanId}": {
      "schema": "ScanResult",
      "description": "Collection of analyzed media and user feedback."
    },
    "/ledger/{hash}": {
      "schema": "LedgerEntry",
      "description": "The 'Blockchain' ledger mapping content hashes to authenticity proofs."
    },
    "/datasets/{datasetId}": {
      "schema": "DatasetFile",
      "description": "Metadata for uploaded training datasets."
    }
  }
}
