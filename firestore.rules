rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DeepScan AI Security Rules - V3.3 (Forensic Resilience)
     *
     * CORE PHILOSOPHY:
     * - Global Intelligence: Shared authenticated access for pattern learning and viral alerts.
     * - User Privacy: Strict ownership of individual scans and identity profiles.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Intelligence Collections (Shared Patterns & Sentinel) ---

    match /alerts/{alertId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    match /datasets/{datasetId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    match /ledger/{hash} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // --- Hierarchical User Data (Private Settings & Investigations) ---

    match /users/{userId} {
      // User Profile
      match /profile {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      
      // Personal Forensic Scans (MediaFiles)
      match /mediaFiles/{mediaFileId} {
        allow get, list, create, update, delete: if isOwner(userId);
        
        // Deepfake Analysis Results
        match /detectionResults/{resultId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }
      }

      // Digital Identity Vault (Backwards compatibility for identities)
      match /identities/{identityId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    // Global Identities (for top-level queries if used)
    match /identities/{identityId} {
      allow get, list, create, update, delete: if isSignedIn();
    }
  }
}