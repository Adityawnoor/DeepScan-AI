rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DeepScan AI Security Rules - V3.2 (Hybrid Resilience)
     *
     * CORE PHILOSOPHY:
     * Strict User-Ownership for private data, and Authenticated-Access for global intelligence.
     * All operations require Firebase Authentication.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Intelligence Collections (Shared Patterns & Sentinel) ---

    match /alerts/{alertId} {
      allow read, write: if isSignedIn();
    }

    match /datasets/{datasetId} {
      allow read, write: if isSignedIn();
    }

    match /ledger/{hash} {
      allow read, write: if isSignedIn();
    }

    // --- Workspace Collections (For Prototype Simplicity) ---

    match /scans/{scanId} {
      allow read, write: if isSignedIn();
    }

    match /identities/{identityId} {
      allow read, write: if isSignedIn();
    }

    // --- Hierarchical User Data (Private Settings) ---

    match /users/{userId} {
      match /profile {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      
      match /mediaFiles/{mediaFileId} {
        allow get, list, create, update, delete: if isOwner(userId);
        
        match /detectionResults/{resultId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }
      }
    }
  }
}