rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DeepScan AI Security Rules - V3.4 (Neural Hub Authorization)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Intelligence Collections (Shared Learning Hub) ---

    match /alerts/{alertId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    match /datasets/{datasetId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    match /ledger/{hash} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // --- Private Forensic Workspaces ---

    match /users/{userId} {
      // User Profile
      match /profile {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      
      // Private Investigative Vault
      match /mediaFiles/{mediaFileId} {
        allow get, list, create, update, delete: if isOwner(userId);
        
        // Deepfake Analysis Results
        match /detectionResults/{resultId} {
          allow get, list, create, update, delete: if isOwner(userId);
        }
      }

      // Digital Identity Vault
      match /identities/{identityId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }
    
    // Global Identities (for sentinel matching)
    match /identities/{identityId} {
      allow get, list, create, update, delete: if isSignedIn();
    }
  }
}